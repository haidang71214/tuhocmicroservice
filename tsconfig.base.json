{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@invoce/constant": ["./libs/constant/src/index.ts"],
      "@common/constant": ["./libs/constant/src/index.ts"],
      "@common/constant/*": ["./libs/constant/src/lib/*"],
      "@common/configuration/*": ["./libs/configuration/src/lib/*"],
      "@common/middlewares/*": ["./libs/middlewares/src/lib/*"],
      "@common/utils/*": ["./libs/utils/src/lib/*"],
      "@common/interfaces/*": ["./libs/interfaces/src/lib/*"],
      "@common/interfaces/gateway/*": ["./libs/interfaces/src/lib/gateway/*"],
      "@common/interceptors/*": ["./libs/interceptors/src/lib/*"],
      "@common/decorator/*": ["./libs/decorators/src/*"],
      "@common/schemas/*": ["./libs/schemas/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
