<%
function numberToVietnameseWords(number) {
    if (number === 0) return 'Không đồng';
    
    const units = ['', ' nghìn', ' triệu', ' tỷ', ' nghìn tỷ', ' triệu tỷ'];
    const digits = ['không', 'một', 'hai', 'ba', 'bốn', 'năm', 'sáu', 'bảy', 'tám', 'chín'];
    
    function readThreeDigits(n, showZeroHundred) {
        let hundred = Math.floor(n / 100);
        let ten = Math.floor((n % 100) / 10);
        let unit = n % 10;
        let res = '';
        
        if (hundred > 0 || showZeroHundred) {
            res += digits[hundred] + ' trăm ';
        }
        
        if (ten > 1) {
            res += digits[ten] + ' mươi ';
        } else if (ten === 1) {
            res += 'mười ';
        } else if (ten === 0 && unit > 0 && (hundred > 0 || showZeroHundred)) {
            res += 'lẻ ';
        }
        
        if (unit === 1 && ten > 1) {
            res += 'mốt';
        } else if (unit === 5 && ten > 0) {
            res += 'lăm';
        } else if (unit > 0 || (hundred === 0 && ten === 0 && unit === 0)) {
            if (unit > 0) {
                res += digits[unit];
            }
        }
        
        return res.trim();
    }
    
    let str = '';
    let group = 0;
    let temp = Math.round(number);
    
    while (temp > 0) {
        let threeDigits = temp % 1000;
        temp = Math.floor(temp / 1000);
        
        if (threeDigits > 0) {
            let showZeroHundred = temp > 0;
            let groupStr = readThreeDigits(threeDigits, showZeroHundred);
            str = groupStr + units[group] + (str ? ' ' + str : '');
        }
        group++;
    }
    
    str = str.trim();
    if (!str) return 'Không đồng';
    return str.charAt(0).toUpperCase() + str.slice(1) + ' đồng chẵn.';
}
%>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Hóa đơn điện tử / e-Invoice</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #1e293b;
            background-color: #ffffff;
            font-size: 13px;
            line-height: 1.5;
        }

        /* Invoice Container */
        .invoice-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            background: #fff;
        }

        /* Header Layout */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid #1e3a8a;
            padding-bottom: 20px;
            margin-bottom: 25px;
        }

        .seller-info {
            width: 60%;
        }

        .company-name {
            font-size: 18px;
            font-weight: 700;
            color: #1e3a8a;
            margin: 0 0 8px 0;
            text-transform: uppercase;
        }

        .company-details {
            font-size: 12px;
            color: #475569;
            line-height: 1.6;
        }

        .company-details strong {
            color: #0f172a;
        }

        .invoice-title-box {
            width: 35%;
            text-align: right;
        }

        .invoice-title {
            font-size: 20px;
            font-weight: 700;
            color: #1e3a8a;
            margin: 0 0 5px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .invoice-subtitle {
            font-size: 12px;
            color: #64748b;
            margin: 0 0 15px 0;
            font-style: italic;
        }

        .meta-grid {
            display: inline-grid;
            grid-template-columns: auto auto;
            gap: 4px 12px;
            font-size: 12px;
            text-align: left;
        }

        .meta-label {
            font-weight: 600;
            color: #475569;
        }

        .meta-value {
            color: #0f172a;
            text-align: right;
        }

        /* Section Title */
        .section-title {
            font-size: 14px;
            font-weight: 600;
            color: #1e3a8a;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 6px;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Buyer / Customer Info */
        .buyer-container {
            margin-bottom: 25px;
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 16px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 150px 1fr;
            gap: 6px 16px;
        }

        .info-label {
            font-weight: 500;
            color: #64748b;
        }

        .info-value {
            color: #0f172a;
        }

        /* Invoice Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }

        .items-table th {
            background-color: #1e3a8a;
            color: #ffffff;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 11px;
            padding: 10px 12px;
            text-align: left;
            border: 1px solid #1e3a8a;
        }

        .items-table th.text-center { text-align: center; }
        .items-table th.text-right { text-align: right; }

        .items-table td {
            padding: 10px 12px;
            border-bottom: 1px solid #e2e8f0;
            border-left: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            color: #334155;
            vertical-align: middle;
        }

        .items-table tr:nth-child(even) td {
            background-color: #f8fafc;
        }

        .text-center { text-align: center; }
        .text-right { text-align: right; }

        /* Calculation Summary */
        .summary-container {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 20px;
        }

        .summary-box {
            width: 45%;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 13px;
            border-bottom: 1px dashed #e2e8f0;
        }

        .summary-row.total {
            border-bottom: 2px double #1e3a8a;
            font-weight: 700;
            font-size: 15px;
            color: #1e3a8a;
            padding-top: 10px;
        }

        .summary-label {
            color: #475569;
        }

        .summary-value {
            color: #0f172a;
        }

        /* Words amount */
        .words-amount {
            margin-bottom: 35px;
            font-style: italic;
            color: #475569;
            background-color: #f1f5f9;
            padding: 12px 16px;
            border-left: 4px solid #1e3a8a;
            border-radius: 0 4px 4px 0;
            font-size: 12px;
        }

        /* Signatures block */
        .signatures {
            display: flex;
            justify-content: space-between;
            margin-top: 40px;
            page-break-inside: avoid;
        }

        .sig-block {
            width: 45%;
            text-align: center;
        }

        .sig-title {
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        .sig-subtitle {
            font-size: 11px;
            color: #64748b;
            margin-bottom: 65px;
            font-style: italic;
        }

        .sig-name {
            font-weight: 600;
            color: #0f172a;
            border-top: 1px dashed #cbd5e1;
            display: inline-block;
            padding-top: 8px;
            min-width: 150px;
        }

        /* Footer notice */
        .footer-notice {
            margin-top: 60px;
            text-align: center;
            font-size: 11px;
            color: #94a3b8;
            border-top: 1px solid #e2e8f0;
            padding-top: 15px;
        }
    </style>
</head>
<body>

<div class="invoice-container">
    <!-- Header: Seller Info & Invoice Title -->
    <div class="header">
        <div class="seller-info">
            <h1 class="company-name">
                <%= typeof seller !== 'undefined' && seller.name ? seller.name : 'CÔNG TY TNHH GIẢI PHÁP CÔNG NGHỆ ACME' %>
            </h1>
            <div class="company-details">
                <div><strong>Mã số thuế (Tax Code):</strong> <%= typeof seller !== 'undefined' && seller.taxCode ? seller.taxCode : '0102030405' %></div>
                <div><strong>Địa chỉ (Address):</strong> <%= typeof seller !== 'undefined' && seller.address ? seller.address : 'Tòa nhà Landmark 81, Điện Biên Phủ, Phường 22, Quận Bình Thạnh, TP. Hồ Chí Minh' %></div>
                <div><strong>Điện thoại (Phone):</strong> <%= typeof seller !== 'undefined' && seller.phone ? seller.phone : '028 3822 8888' %> | <strong>Email:</strong> <%= typeof seller !== 'undefined' && seller.email ? seller.email : 'billing@acme-tech.vn' %></div>
                <div><strong>Số tài khoản (Bank Account):</strong> <%= typeof seller !== 'undefined' && seller.bankAccount ? seller.bankAccount : '123456789 - Ngân hàng TMCP Ngoại thương Việt Nam (Vietcombank)' %></div>
            </div>
        </div>
        
        <div class="invoice-title-box">
            <h2 class="invoice-title">HÓA ĐƠN GTGT</h2>
            <div class="invoice-subtitle">VAT Invoice / e-Invoice</div>
            
            <div class="meta-grid">
                <span class="meta-label">Ký hiệu (Serial):</span>
                <span class="meta-value"><%= typeof invoice !== 'undefined' && invoice.serial ? invoice.serial : '1C26TAA' %></span>
                
                <span class="meta-label">Số (No.):</span>
                <span class="meta-value" style="color: #ef4444; font-weight: 700;">
                    <%= typeof einvoice !== 'undefined' && einvoice && einvoice.id ? String(einvoice.id).padStart(7, '0') : '0000123' %>
                </span>
                
                <span class="meta-label">Ngày (Date):</span>
                <span class="meta-value"><%= typeof invoice !== 'undefined' && invoice.date ? invoice.date : '18/07/2026' %></span>
            </div>
        </div>
    </div>

    <!-- Buyer Info -->
    <div class="section-title">Thông tin người mua (Customer Details)</div>
    <div class="buyer-container">
        <div class="info-grid">
            <span class="info-label">Khách hàng (Client):</span>
            <span class="info-value"><strong><%= typeof client !== 'undefined' && client.name ? client.name : (typeof buyer !== 'undefined' && buyer.companyName ? buyer.companyName : 'TỔNG CÔNG TY CỔ PHẦN ĐẦU TƯ TOÀN CẦU') %></strong></span>
            
            <span class="info-label">Email:</span>
            <span class="info-value"><%= typeof client !== 'undefined' && client.email ? client.email : (typeof buyer !== 'undefined' && buyer.email ? buyer.email : 'contact@client-company.com') %></span>
            
            <span class="info-label">Địa chỉ (Address):</span>
            <span class="info-value"><%= typeof client !== 'undefined' && client.address ? client.address : (typeof buyer !== 'undefined' && buyer.address ? buyer.address : 'Số 15 Lê Lợi, Phường Bến Nghé, Quận 1, TP. Hồ Chí Minh') %></span>
            
            <span class="info-label">Hình thức TT (Payment):</span>
            <span class="info-value"><%= typeof buyer !== 'undefined' && buyer.paymentMethod ? buyer.paymentMethod : 'Chuyển khoản (Bank Transfer)' %></span>
        </div>
    </div>

    <!-- Items Table -->
    <div class="section-title">Chi tiết hàng hóa, dịch vụ (Itemized Charges)</div>
    <table class="items-table">
        <thead>
            <tr>
                <th class="text-center" style="width: 5%;">STT<br><span style="font-size: 9px; font-weight: normal;">No.</span></th>
                <th style="width: 40%;">Tên hàng hóa, dịch vụ<br><span style="font-size: 9px; font-weight: normal;">Description of goods/services</span></th>
                <th class="text-center" style="width: 10%;">Đơn vị tính<br><span style="font-size: 9px; font-weight: normal;">Unit</span></th>
                <th class="text-center" style="width: 10%;">Số lượng<br><span style="font-size: 9px; font-weight: normal;">Qty</span></th>
                <th class="text-right" style="width: 15%;">Đơn giá<br><span style="font-size: 9px; font-weight: normal;">Unit Price</span></th>
                <th class="text-right" style="width: 20%;">Thành tiền<br><span style="font-size: 9px; font-weight: normal;">Total Amount</span></th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof items !== 'undefined' && items && items.length > 0) { %>
                <% items.forEach((item, index) => { %>
                    <tr>
                        <td class="text-center"><%= index + 1 %></td>
                        <td><%= item.name %></td>
                        <td class="text-center"><%= item.unit || '-' %></td>
                        <td class="text-center"><%= item.quantity %></td>
                        <td class="text-right"><%= (typeof item.unitPrice !== 'undefined' ? item.unitPrice : item.price).toLocaleString('vi-VN') %></td>
                        <td class="text-right"><%= (typeof item.total !== 'undefined' ? item.total : (item.quantity * (item.unitPrice || item.price || 0))).toLocaleString('vi-VN') %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <!-- Dummy Items for static display -->
                <tr>
                    <td class="text-center">1</td>
                    <td>Dịch vụ tư vấn giải pháp Chuyển đổi số (Enterprise Digital Transformation Consulting Service)</td>
                    <td class="text-center">Gói (Package)</td>
                    <td class="text-center">1</td>
                    <td class="text-right">50.000.000</td>
                    <td class="text-right">50.000.000</td>
                </tr>
                <tr>
                    <td class="text-center">2</td>
                    <td>Bản quyền phần mềm Acme Core ERP - Standard Edition (Subscription license for Acme Core ERP)</td>
                    <td class="text-center">Người dùng (User)</td>
                    <td class="text-center">10</td>
                    <td class="text-right">1.500.000</td>
                    <td class="text-right">15.000.000</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <!-- Calculations & Summary -->
    <div class="summary-container">
        <div class="summary-box">
            <div class="summary-row">
                <span class="summary-label">Cộng tiền hàng (Subtotal):</span>
                <span class="summary-value">
                    <%= typeof subtotal !== 'undefined' ? subtotal.toLocaleString('vi-VN') : (typeof summary !== 'undefined' && summary.subTotal ? summary.subTotal.toLocaleString('vi-VN') : '65.000.000') %> VND
                </span>
            </div>
            <div class="summary-row">
                <span class="summary-label">Thuế suất GTGT (VAT Rate):</span>
                <span class="summary-value">
                    <%= (typeof subtotal !== 'undefined' && typeof vatAmount !== 'undefined' && subtotal > 0) ? ((vatAmount / subtotal) * 100).toFixed(0) + '%' : (typeof summary !== 'undefined' && summary.vatRate ? summary.vatRate : '10%') %>
                </span>
            </div>
            <div class="summary-row">
                <span class="summary-label">Tiền thuế GTGT (VAT Amount):</span>
                <span class="summary-value">
                    <%= typeof vatAmount !== 'undefined' ? vatAmount.toLocaleString('vi-VN') : (typeof summary !== 'undefined' && summary.vatAmount ? summary.vatAmount.toLocaleString('vi-VN') : '6.500.000') %> VND
                </span>
            </div>
            <div class="summary-row total">
                <span class="summary-label">Tổng tiền thanh toán (Total):</span>
                <span class="summary-value">
                    <%= typeof totalAmount !== 'undefined' ? totalAmount.toLocaleString('vi-VN') : (typeof summary !== 'undefined' && summary.total ? summary.total.toLocaleString('vi-VN') : '71.500.000') %> VND
                </span>
            </div>
        </div>
    </div>

    <!-- Amount in words -->
    <div class="words-amount">
        <strong>Số tiền viết bằng chữ (Amount in words):</strong> 
        <%= typeof totalAmount !== 'undefined' ? numberToVietnameseWords(totalAmount) : (typeof summary !== 'undefined' && summary.totalWords ? summary.totalWords : 'Bảy mươi mốt triệu năm trăm nghìn đồng chẵn.') %>
    </div>

    <!-- Signatures -->
    <div class="signatures">
        <div class="sig-block">
            <div class="sig-title">Người mua hàng (Buyer)</div>
            <div class="sig-subtitle">Ký, ghi rõ họ tên (Signature & full name)</div>
            <!-- Space for signature -->
            <div class="sig-name">
                <%= typeof client !== 'undefined' && client.name ? client.name : (typeof buyer !== 'undefined' && buyer.contactName ? buyer.contactName : '') %>
            </div>
        </div>
        <div class="sig-block">
            <div class="sig-title">Người bán hàng (Seller)</div>
            <div class="sig-subtitle">Ký điện tử bởi ACME Tech (Digitally signed)</div>
            <!-- Space for signature -->
            <div class="sig-name">
                <%= typeof seller !== 'undefined' && seller.name ? seller.name : 'ACME TECH Co., Ltd' %>
            </div>
        </div>
    </div>

    <!-- Footer Notice -->
    <div class="footer-notice">
        Hóa đơn điện tử được khởi tạo và phát hành hợp lệ theo quy định của pháp luật Việt Nam.<br>
        (This electronic invoice is legally issued in accordance with Vietnamese tax regulations.)
    </div>
</div>

</body>
</html>
