{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@common/constant$": "<rootDir>/../../../libs/constant/src/index.ts",
    "^@common/constant/(.*)$": "<rootDir>/../../../libs/constant/src/lib/$1"
  }
}
