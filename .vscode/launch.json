{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug invoce with Nx",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nx", "serve", "invoce"],
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/apps/invoce/dist/**/*.(m|c|)js", "!**/node_modules/**"]
    },
